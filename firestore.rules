rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    match /users_profiles/{userId} {
      allow read, write: if true;
    }

    match /employees/{employeeId} {
      allow read, write: if true;
    }

    match /clock_ins/{clockInId} {
      allow read, write: if true;
    }

    match /non_conformities/{ncId} {
      allow read, write: if true;
    }

    match /holerite_summaries/{hsId} {
      allow read, write: if true;
    }

    match /candidates/{candId} {
      allow read, write: if true;
    }

    match /jira_tasks/{taskId} {
      allow read, write: if true;
    }

    match /employee_trainings/{trId} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
